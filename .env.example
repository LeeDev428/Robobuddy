# ============================================
# RoboBuddy Environment Variables Template
# ============================================
# Copy this to .env and fill in your values
# Used by: ai_robot/config.py

# ------  Groq API (Cloud LLM) ------
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ------ System Prompt (Robot Personality) ------
SYSTEM_PROMPT=You are RoboBuddy, a friendly educational AI companion robot. Keep responses short and engaging.

# ------ Whisper STT (Local speech recognition) ------
# Options: tiny, base, small, medium, large
WHISPER_MODEL=base
LISTEN_TIMEOUT_SEC=6
PHRASE_TIME_LIMIT_SEC=10

# ------ YOLO Vision (Person Detection) ------
# Options: yolov8n.pt (nano, fast), yolov8s.pt (small), yolov8m.pt (medium)
YOLO_MODEL=yolov8n.pt
CAMERA_INDEX=0
PERSON_CONFIDENCE=0.45

# ------ Raspberry Pi Socket Connection ------
ROBOT_HOST=192.168.1.50
ROBOT_PORT=5000
SOCKET_TIMEOUT_SEC=2.0

# ------ Text-to-Speech (pyttsx3) ------
TTS_RATE=170
TTS_VOLUME=1.0

# ------ Data Storage (Laptop-side logging) ------
ROBOBUDDY_DATA_DIR=./robobuddy_data

# ------  Optional: Advanced Settings ------
# YOLO_DEVICE=cpu              # Use 'cpu' or 'cuda' for GPU (auto-detected)
# STORAGE_RETENTION_DAYS=90    # Auto-delete logs older than N days (future feature)
